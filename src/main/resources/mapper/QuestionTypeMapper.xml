<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.bishe.question.mapper.QuestionTypeMapper">

    <cache/>

    <resultMap id="questionTypeMap" type="org.bishe.question.entity.QuestionTypeEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="displayName" column="display_name"/>
    </resultMap>

    <select id="findById" resultMap="questionTypeMap">
        SELECT id, name, display_name FROM question_types WHERE id = #{id}
    </select>

    <select id="findByName" resultMap="questionTypeMap">
        SELECT id, name, display_name FROM question_types WHERE name = #{name}
    </select>

    <select id="findAll" resultMap="questionTypeMap">
        SELECT id, name, display_name FROM question_types ORDER BY id
    </select>

</mapper>
